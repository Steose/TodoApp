@model TodoApp.Models.TodoItem

@{
    ViewData["Title"] = "Delete Todo";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-8 col-md-10">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-danger text-white border-0">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-trash-alt fa-lg me-3"></i>
                        <div>
                            <h4 class="mb-0">Delete Todo</h4>
                            <small>Confirm deletion of this todo item</small>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning" role="alert">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Warning!</strong> This action cannot be undone. Are you sure you want to delete this
                        todo item?
                    </div>

                    <div class="card border mb-4">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fas fa-info-circle me-2 text-primary"></i>
                                Todo Item Details
                            </h5>
                        </div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-4 fw-bold">
                                    <i class="fas fa-heading me-2 text-primary"></i>Title
                                </dt>
                                <dd class="col-sm-8">@Model.Title</dd>

                                <dt class="col-sm-4 fw-bold">
                                    <i class="fas fa-align-left me-2 text-primary"></i>Description
                                </dt>
                                <dd class="col-sm-8">
                                    @if (!string.IsNullOrEmpty(Model.Description))
                                    {
                                        @Model.Description
                                    }
                                    else
                                    {
                                        <em class="text-muted">No description provided</em>
                                    }
                                </dd>

                                <dt class="col-sm-4 fw-bold">
                                    <i class="fas fa-check-circle me-2 text-success"></i>Status
                                </dt>
                                <dd class="col-sm-8">
                                    @if (Model.IsCompleted)
                                    {
                                        <span class="badge bg-success fs-6">
                                            <i class="fas fa-check me-1"></i>Completed
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark fs-6">
                                            <i class="fas fa-clock me-1"></i>Pending
                                        </span>
                                    }
                                </dd>

                                <dt class="col-sm-4 fw-bold">
                                    <i class="fas fa-calendar-alt me-2 text-primary"></i>Created At
                                </dt>
                                <dd class="col-sm-8">@Model.CreatedAt.ToString("MMM dd, yyyy 'at' h:mm tt")</dd>
                            </dl>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post" class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <input type="hidden" asp-for="Id" />
                        <a asp-action="Index" class="btn btn-outline-secondary me-md-2">
                            <i class="fas fa-arrow-left me-2"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-danger btn-lg">
                            <i class="fas fa-trash me-2"></i>Delete Todo
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>