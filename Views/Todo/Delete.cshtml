@model TodoApp.Models.TodoItem

@{
    ViewData["Title"] = "Delete Todo";
}

<h1>Delete Todo</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Todo Item</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Title</dd>
        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>
        <dt class="col-sm-2">Completed</dt>
        <dd class="col-sm-10">@(Model.IsCompleted ? "Yes" : "No")</dd>
        <dt class="col-sm-2">Created At</dt>
        <dd class="col-sm-10">@Model.CreatedAt.ToString("g")</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>