@model IEnumerable<TodoApp.Models.TodoItem>

@{
    ViewData["Title"] = "Todo List";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Todo List</h1>
        <div>
            <a asp-action="Create" class="btn btn-primary">Create Todo</a>
            <a asp-action="Item" class="btn btn-success ms-2">Quick Add</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Error
        </div>
    }

    @if (ViewBag.Info != null)
    {
        <div class="alert alert-info">
            @ViewBag.Info
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <table class="table table-bordered table-striped align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Completed</th>
                    <th>Created At</th>
                    <th style="width: 320px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var todo in Model)
                {
                    <tr>
                        <td>@todo.Title</td>
                        <td>@todo.Description</td>
                        <td>
                            @if (todo.IsCompleted)
                            {
                                <span class="badge bg-success">Completed</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </td>
                        <td>@todo.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@todo.Id" class="btn btn-info btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@todo.Id" class="btn btn-warning btn-sm ms-1">Edit</a>
                            <a asp-action="Delete" asp-route-id="@todo.Id" class="btn btn-danger btn-sm ms-1">Delete</a>

                            <form asp-action="ToggleComplete" asp-route-id="@todo.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-secondary btn-sm ms-1">Toggle</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>