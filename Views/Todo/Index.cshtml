@model IEnumerable<TodoApp.Models.TodoItem>

@{
    ViewData["Title"] = "Todo List";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h2 mb-0 text-primary">📝 Todo List</h1>
                    <p class="text-muted mb-0">Manage your tasks efficiently</p>
                </div>
                <a asp-action="Create" class="btn btn-primary btn-lg">
                    <i class="fas fa-plus me-2"></i>Create New Todo
                </a>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="row mb-3">
            <div class="col-12">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        @ViewBag.Error
                    </div>
                }
                else if (ViewBag.Info != null)
                {
                    <div class="alert alert-info" role="alert">
                        <i class="fas fa-info-circle me-2"></i>
                        @ViewBag.Info
                    </div>
                }
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center py-5">
                        <div class="mb-3">
                            <i class="fas fa-clipboard-list fa-3x text-muted"></i>
                        </div>
                        <h4 class="text-muted">No todos yet</h4>
                        <p class="text-muted mb-4">Get started by creating your first todo item</p>
                        <a asp-action="Item" class="btn btn-primary">
                            <i class="fas fa-plus me-2"></i>Create Your First Todo
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model)
            {
                <div class="col-xl-4 col-lg-6 col-md-6 col-sm-12">
                    <div class="card h-100 border-0 shadow-sm @(item.IsCompleted ? "bg-light" : "")">
                        <div class="card-header bg-white border-0 pb-0">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5
                                    class="card-title mb-0 @(item.IsCompleted ? "text-decoration-line-through text-muted" : "text-dark")">
                                    @item.Title
                                </h5>
                                @if (item.IsCompleted)
                                {
                                    <span class="badge bg-success">
                                        <i class="fas fa-check me-1"></i>Completed
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="fas fa-clock me-1"></i>Pending
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <p class="card-text @(item.IsCompleted ? "text-muted" : "text-secondary")">
                                    @item.Description
                                </p>
                            }
                            else
                            {
                                <p class="card-text text-muted fst-italic">No description provided</p>
                            }
                            <div class="mt-3">
                                <small class="text-muted">
                                    <i class="fas fa-calendar-alt me-1"></i>
                                    Created @item.CreatedAt.ToString("MMM dd, yyyy 'at' h:mm tt")
                                </small>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 pt-0">
                            <div class="d-flex gap-2 flex-wrap">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-edit me-1"></i>Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">
                                    <i class="fas fa-trash me-1"></i>Delete
                                </a>
                                <form asp-action="ToggleComplete" asp-route-id="@item.Id" method="post" class="d-inline">
                                    <button type="submit"
                                            class="btn btn-sm @(item.IsCompleted ? "btn-outline-secondary" : "btn-outline-success")">
                                        <i class="fas fa-@(item.IsCompleted ? "undo" : "check") me-1"></i>
                                        @(item.IsCompleted ? "Mark Incomplete" : "Mark Complete")
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="row mt-4">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-md-4 mb-3 mb-md-0">
                                <div class="h4 text-primary mb-1">@Model.Count()</div>
                                <small class="text-muted">Total Todos</small>
                            </div>
                            <div class="col-md-4 mb-3 mb-md-0">
                                <div class="h4 text-success mb-1">@Model.Count(x => x.IsCompleted)</div>
                                <small class="text-muted">Completed</small>
                            </div>
                            <div class="col-md-4">
                                <div class="h4 text-warning mb-1">@Model.Count(x => !x.IsCompleted)</div>
                                <small class="text-muted">Pending</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>