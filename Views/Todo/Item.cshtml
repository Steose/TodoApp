@model TodoApp.Models.TodoItem

@{
    ViewData["Title"] = "Add Todo Item";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-8 col-md-10">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-success text-white border-0">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-plus-circle fa-lg me-3"></i>
                        <div>
                            <h4 class="mb-0">Add New Todo Item</h4>
                            <small>Quick add a new task to your todo list</small>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i>
                            @ViewBag.Message
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Item" method="post" class="needs-validation" novalidate>
                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold">
                                <i class="fas fa-heading me-2 text-primary"></i>Title <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Title" class="form-control form-control-lg"
                                   placeholder="Enter todo title..." required />
                            <div class="invalid-feedback">
                                Please provide a valid title.
                            </div>
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">
                                <i class="fas fa-align-left me-2 text-primary"></i>Description
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="3"
                                      placeholder="Enter todo description (optional)..."></textarea>
                            <div class="form-text text-muted">
                                Provide additional details about this todo item
                            </div>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" asp-for="IsCompleted"
                                       id="IsCompletedCheck">
                                    <label class="form-check-label fw-bold" for="IsCompletedCheck">
                                        <i class="fas fa-check-circle me-2 text-success"></i>
                                        Mark as completed
                                    </label>
                                    <div class="form-text text-muted">
                                        Check this if the todo is already completed
                                    </div>
                                </div>
                            </div>

                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                <a asp-action="Index" class="btn btn-outline-secondary me-md-2">
                                    <i class="fas fa-list me-2"></i>View All Todos
                                </a>
                                <button type="submit" class="btn btn-success btn-lg">
                                    <i class="fas fa-plus me-2"></i>Add Todo
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            // Bootstrap form validation
            (function () {
                'use strict'
                var forms = document.querySelectorAll('.needs-validation')
                Array.prototype.slice.call(forms)
                    .forEach(function (form) {
                        form.addEventListener('submit', function (event) {
                            if (!form.checkValidity()) {
                                event.preventDefault()
                                event.stopPropagation()
                            }
                            form.classList.add('was-validated')
                        }, false)
                    })
            })()
        </script>
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
