@{
    ViewData["Title"] = "TodoApp Landing";
}

<section class="bg-light py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="card border-0 shadow-sm p-4">
                    <span class="badge bg-primary mb-3">Productivity Platform</span>
                    <h1 class="display-4 fw-bold">Take Control of Your Tasks</h1>
                    <p class="lead text-secondary mb-4">
                        TodoApp helps you manage, organize, and complete your daily tasks with ease.
                        Use a modern todo manager with cloud-sync, progress tracking, and smart workflow support.
                    </p>
                    <div class="d-grid d-sm-flex gap-2">
                        <a asp-controller="Todo" asp-action="Item" class="btn btn-primary btn-lg">
                            <i class="fas fa-list-check me-2"></i>View Todos
                        </a>
                        <a asp-controller="Todo" asp-action="Item" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-plus me-2"></i>Add Quick Todo
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1515879218367-8466d910aaa4?auto=format&fit=crop&w=1200&q=80"
                         class="img-fluid" alt="Landing hero image">
                </div>
            </div>
        </div>

        <div class="row mt-5">
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm h-100 p-4">
                    <h5 class="fw-bold">Organize Quickly</h5>
                    <p class="text-muted">Create, update, and remove todos with a clean interface and instant feedback.
                    </p>
                    <a asp-controller="Todo" asp-action="Index" class="btn btn-sm btn-primary mt-3">Go to /Todos</a>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm h-100 p-4">
                    <h5 class="fw-bold">Add a Todo Item</h5>
                    <p class="text-muted">Quick add a new item through the form route.</p>
                    <a asp-controller="Todo" asp-action="Item" class="btn btn-sm btn-outline-primary mt-3">Open
                        /Todos/Item</a>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="card border-0 shadow-sm h-100 p-4">
                        <h5 class="fw-bold">Track Progress</h5>
                        <p class="text-muted">Use progress indicators and tags to stay on top of what matters today.</p>
                        <a asp-controller="Todo" asp-action="Index" class="btn btn-sm btn-success mt-3">View Stats</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
