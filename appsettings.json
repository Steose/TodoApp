{
  "DatabaseProvider": {
    "Provider": "MongoDb"
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "TodoAppDb",
    "TodoCollectionName": "Todos"
  },
  "CosmosMongo": {
    "ConnectionString": "mongodb://your-cosmos-user:your-password@your-account.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&appName=@your-account@",
    "DatabaseName": "TodoAppDb",
    "TodoCollectionName": "Todos"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}