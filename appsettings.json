{
  "DatabaseProvider": {
    "Provider": "MongoDb"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FeatureFlags": {
    "UseMongoDb": false,
    "UseCosmosMongo": false,
    "UseAzureKeyVault": false
  },
  "MongoDb": {
    "ConnectionString": "mongodb://{username}:{password}@{hostname}:{port}",
    "DatabaseName": "TodoAppDb",
    "TodoCollectionName": "Todos"
  },
  "CosmosMongo": {
    "ConnectionString": "mongodb://your-cosmos-user:your-password@your-account.mongo.cosmos.azure.com:10255/TodoAppDb?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&authMechanism=SCRAM-SHA-256&appName=@your-account@",
    "DatabaseName": "TodoAppDb",
    "TodoCollectionName": "Todos"
  },
  "AzureKeyVault": {
    "KeyVaultUri": "https://{keyvaultname}.vault.azure.net/"
  }
}
